{
  "tasks": [
    {
      "name": "me",
      "command": "echo \"`whoami`\"",
      "description": "Display current user"
    },
    {
      "name": "update",
      "command": "cargo update",
      "description": "Update dependencies"
    },
    {
      "name": "lint",
      "command": "cargo clippy -- -D warnings",
      "description": "Run linter with warnings as errors"
    },
    {
      "name": "fmt:fix",
      "command": "cargo fmt --all",
      "description": "Format all code"
    },
    {
      "name": "clean",
      "command": "cargo clean",
      "description": "Clean build artifacts"
    },
    {
      "name": "release",
      "command": [
        "cargo build --release",
        "cargo test",
        "cargo clippy -- -D warnings"
      ],
      "description": "Build, test and lint for release"
    },
    {
      "name": "check",
      "command": "cargo check",
      "description": "Check code for errors"
    },
    {
      "name": "install",
      "command": "cargo install --path .",
      "description": "Install locally"
    },
    {
      "name": "build",
      "command": "cargo build --release",
      "description": "Build in release mode"
    },
    {
      "name": "doc",
      "command": "cargo doc --no-deps --open",
      "description": "Generate and open documentation"
    },
    {
      "name": "bench",
      "command": "cargo bench",
      "description": "Run benchmarks"
    },
    {
      "name": "publish",
      "command": "cargo publish",
      "description": "Publish to crates.io"
    },
    {
      "name": "test",
      "command": "cargo test",
      "description": "Run tests"
    },
    {
      "name": "fmt",
      "command": "cargo fmt --all -- --check",
      "description": "Check if code is formatted"
    },
    {
      "name": "build:mode",
      "command": "cargo build --{{mode=[debug, release]}}",
      "description": "Build with specified mode"
    },
    {
      "name": "test:type",
      "command": "cargo test --{{type=[lib, doc, all]}}",
      "description": "Run specific type of tests"
    }
  ]
}
