{
  "tasks": [
    {
      "name": "start",
      "command": "node {{file=index.js}}",
      "description": "Run start"
    },
    {
      "name": "dev",
      "command": "nodemon {{file=index.js}} --watch {{path=src}}",
      "description": "Run dev"
    },
    {
      "name": "test",
      "command": "jest {{path=tests}} --verbose",
      "description": "Run test"
    },
    {
      "name": "test watch",
      "command": "jest --watch {{path=tests}}",
      "description": "Test Watch"
    },
    {
      "name": "test coverage",
      "command": "jest --coverage --coverageDirectory={{dir=coverage}}",
      "description": "Test Coverage"
    },
    {
      "name": "lint",
      "command": "eslint {{path=.}} --ext {{ext=[.js,.ts,.jsx,.tsx]}}",
      "description": "Run lint"
    },
    {
      "name": "lint fix",
      "command": "eslint {{path=.}} --ext {{ext=[.js,.ts,.jsx,.tsx]}} --fix",
      "description": "Lint Fix"
    },
    {
      "name": "build",
      "command": "tsc --project {{file=tsconfig.json}} --outDir {{dir=dist}}",
      "description": "Run build"
    },
    {
      "name": "clean",
      "command": "rm -rf {{dir=[dist,coverage,node_modules]}}",
      "description": "Run clean"
    },
    {
      "name": "install deps",
      "command": "npm install --production",
      "description": "Install Deps"
    },
    {
      "name": "update deps",
      "command": "npm update {{scope=@types}}",
      "description": "Update Deps"
    },
    {
      "name": "audit",
      "command": "npm audit fix {{level=[low,moderate,high,critical]}}",
      "description": "Run audit"
    },
    {
      "name": "typecheck",
      "command": "tsc --noEmit --strict",
      "description": "Run typecheck"
    },
    {
      "name": "format",
      "command": "prettier --write {{path=.}} --ignore-path {{file=.prettierignore}}",
      "description": "Run format"
    },
    {
      "name": "deploy",
      "command": "npm publish --tag {{tag=[latest,beta,alpha]}} --access {{access=[public,restricted]}}",
      "description": "Run deploy"
    },
    {
      "name": "serve",
      "command": "node {{file=dist/index.js}} --port={{port=3000}} --env={{env=[development,staging,production]}}",
      "description": "Run serve"
    }
  ]
}